UID:coptic2026-79@coptic-calendar.app
DTSTART;VALUE=DATE:20260922
DTEND;VALUE=DATE:20260923
SUMMARY:Council of Ephesus (431 AD) (12 Thoout)
DESCRIPTION:12 Thoout 1743 AM - Third Ecumenical Council. Affirmed Mary as Theotokos. Condemned Nestorianism.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-83@coptic-calendar.app
DTSTART;VALUE=DATE:20261005
DTEND;VALUE=DATE:20261006
SUMMARY:St. Maurice / Jonah the Prophet (25 Thoout)
DESCRIPTION:25 Thoout 1743 AM - St. Maurice: commander of the Theban Legion. Jonah: prophet who preached to Nineveh.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
