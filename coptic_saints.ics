BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Coptic Orthodox Calendar//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALNAME:Coptic Saints (Blue)
X-WR-TIMEZONE:Australia/Sydney
BEGIN:VEVENT
UID:coptic2026-1@coptic-calendar.app
DTSTART;VALUE=DATE:20260102
DTEND;VALUE=DATE:20260103
SUMMARY:St. Ignatius of Antioch (24 Kiahk)
DESCRIPTION:24 Kiahk 1742 AM - Bishop of Antioch and early Church Father. Fed to lions in Rome c. 108 AD. Author of seven epistles.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-4@coptic-calendar.app
DTSTART;VALUE=DATE:20260112
DTEND;VALUE=DATE:20260113
SUMMARY:St. John the Apostle (4 Tobe)
DESCRIPTION:4 Tobe 1742 AM - The beloved disciple, author of the Gospel of John, three Epistles, and the Book of Revelation.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-8@coptic-calendar.app
DTSTART;VALUE=DATE:20260121
DTEND;VALUE=DATE:20260122
SUMMARY:St. Demiana and the 40 Virgins (13 Tobe)
DESCRIPTION:13 Tobe 1742 AM - Virgin martyr who inspired 40 companions to remain faithful. Martyred under Diocletian.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-9@coptic-calendar.app
DTSTART;VALUE=DATE:20260122
DTEND;VALUE=DATE:20260123
SUMMARY:St. Maximus (14 Tobe)
DESCRIPTION:14 Tobe 1742 AM - Desert father known for confession and asceticism in the Egyptian desert.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-10@coptic-calendar.app
DTSTART;VALUE=DATE:20260125
DTEND;VALUE=DATE:20260126
SUMMARY:St. Domadius (17 Tobe)
DESCRIPTION:17 Tobe 1742 AM - Desert father known for his extreme asceticism and prayer life.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-11@coptic-calendar.app
DTSTART;VALUE=DATE:20260130
DTEND;VALUE=DATE:20260131
SUMMARY:St. Anthony the Great (22 Tobe)
DESCRIPTION:22 Tobe 1742 AM - Father of all monks. Lived 105 years in the Egyptian desert. His life was written by St. Athanasius.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-15@coptic-calendar.app
DTSTART;VALUE=DATE:20260208
DTEND;VALUE=DATE:20260209
SUMMARY:Council of Constantinople (381 AD) (1 Meshir)
DESCRIPTION:1 Meshir 1742 AM - Second Ecumenical Council. Affirmed the divinity of the Holy Spirit and expanded the Nicene Creed.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-16@coptic-calendar.app
DTSTART;VALUE=DATE:20260209
DTEND;VALUE=DATE:20260210
SUMMARY:St. Paul the First Hermit (2 Meshir)
DESCRIPTION:2 Meshir 1742 AM - First Christian hermit. Lived in a cave in the Egyptian desert for nearly 100 years.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-19@coptic-calendar.app
DTSTART;VALUE=DATE:20260217
DTEND;VALUE=DATE:20260218
SUMMARY:St. James son of Alphaeus (10 Meshir)
DESCRIPTION:10 Meshir 1742 AM - One of the twelve apostles. Also known as James the Less. Martyred by stoning in Jerusalem.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-20@coptic-calendar.app
DTSTART;VALUE=DATE:20260221
DTEND;VALUE=DATE:20260222
SUMMARY:St. Severus of Antioch (14 Meshir)
DESCRIPTION:14 Meshir 1742 AM - Patriarch of Antioch (512-538 AD). Defender of Miaphysite Christology and prolific theologian.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-21@coptic-calendar.app
DTSTART;VALUE=DATE:20260223
DTEND;VALUE=DATE:20260224
SUMMARY:St. Elizabeth (16 Meshir)
DESCRIPTION:16 Meshir 1742 AM - Mother of St. John the Baptist and cousin of the Virgin Mary. Her story is told in Luke 1.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-22@coptic-calendar.app
DTSTART;VALUE=DATE:20260224
DTEND;VALUE=DATE:20260225
SUMMARY:St. Mina the Monk (17 Meshir)
DESCRIPTION:17 Meshir 1742 AM - Egyptian monk and ascetic of the desert.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-23@coptic-calendar.app
DTSTART;VALUE=DATE:20260302
DTEND;VALUE=DATE:20260303
SUMMARY:St. Eusebius of Caesarea (23 Meshir)
DESCRIPTION:23 Meshir 1742 AM - Father of Church History. Bishop of Caesarea and author of the Ecclesiastical History.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-24@coptic-calendar.app
DTSTART;VALUE=DATE:20260308
DTEND;VALUE=DATE:20260309
SUMMARY:St. Polycarp of Smyrna (29 Meshir)
DESCRIPTION:29 Meshir 1742 AM - Disciple of St. John the Apostle. Bishop of Smyrna. Martyred by burning at age 86 (c. 155 AD).
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-25@coptic-calendar.app
DTSTART;VALUE=DATE:20260309
DTEND;VALUE=DATE:20260310
SUMMARY:Pope Cyril VI (30 Meshir)
DESCRIPTION:30 Meshir 1742 AM - 116th Pope of Alexandria (1959-1971). Known for miracles and deep prayer life. Built St. Mina monastery.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-26@coptic-calendar.app
DTSTART;VALUE=DATE:20260314
DTEND;VALUE=DATE:20260315
SUMMARY:St. Sarapamon (5 Paremhotep)
DESCRIPTION:5 Paremhotep 1742 AM - Bishop of Nikiou. Martyred during the Diocletian persecution. Known as the veiled bishop.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-27@coptic-calendar.app
DTSTART;VALUE=DATE:20260317
DTEND;VALUE=DATE:20260318
SUMMARY:St. Matthias the Apostle (8 Paremhotep)
DESCRIPTION:8 Paremhotep 1742 AM - Chosen to replace Judas Iscariot (Acts 1:26). Preached in Judea and was martyred.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-29@coptic-calendar.app
DTSTART;VALUE=DATE:20260326
DTEND;VALUE=DATE:20260327
SUMMARY:St. Sidhom Bishay (17 Paremhotep)
DESCRIPTION:17 Paremhotep 1742 AM - Coptic layman martyred in Damietta (1844). Last Coptic martyr before the modern era.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-30@coptic-calendar.app
DTSTART;VALUE=DATE:20260402
DTEND;VALUE=DATE:20260403
SUMMARY:Apparition at Zeitoun (24 Paremhotep)
DESCRIPTION:24 Paremhotep 1742 AM - Apparition of the Blessed Virgin Mary above Zeitoun Church, Cairo (1968). Witnessed by millions.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-33@coptic-calendar.app
DTSTART;VALUE=DATE:20260405
DTEND;VALUE=DATE:20260406
SUMMARY:St. Macarius the Great (27 Paremhotep)
DESCRIPTION:27 Paremhotep 1742 AM - Father of Scetis monasticism. Founded the monastery in Wadi El Natrun. Departed 390 AD.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-35@coptic-calendar.app
DTSTART;VALUE=DATE:20260406
DTEND;VALUE=DATE:20260407
SUMMARY:Emperor Constantine the Great (28 Paremhotep)
DESCRIPTION:28 Paremhotep 1742 AM - First Christian Roman Emperor. Convened the Council of Nicaea (325 AD). Departed 337 AD.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-40@coptic-calendar.app
DTSTART;VALUE=DATE:20260414
DTEND;VALUE=DATE:20260415
SUMMARY:St. Mary of Egypt (6 Parmoute)
DESCRIPTION:6 Parmoute 1742 AM - Repentant saint who lived 47 years in the desert. Model of repentance in the Coptic tradition.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-41@coptic-calendar.app
DTSTART;VALUE=DATE:20260425
DTEND;VALUE=DATE:20260426
SUMMARY:St. James the Apostle (17 Parmoute)
DESCRIPTION:17 Parmoute 1742 AM - Son of Zebedee, brother of John. First apostle to be martyred (Acts 12:2).
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-42@coptic-calendar.app
DTSTART;VALUE=DATE:20260501
DTEND;VALUE=DATE:20260502
SUMMARY:St. George the Martyr (23 Parmoute)
DESCRIPTION:23 Parmoute 1742 AM - Roman soldier and Great Martyr. Patron saint of many Coptic churches. Martyred c. 303 AD.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-43@coptic-calendar.app
DTSTART;VALUE=DATE:20260508
DTEND;VALUE=DATE:20260509
SUMMARY:St. Mark the Evangelist (30 Parmoute)
DESCRIPTION:30 Parmoute 1742 AM - Author of the Gospel of Mark. Founder of the Church of Alexandria. First Pope of the Coptic Church.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-44@coptic-calendar.app
DTSTART;VALUE=DATE:20260515
DTEND;VALUE=DATE:20260516
SUMMARY:St. Athanasius the Apostolic (7 Pashons)
DESCRIPTION:7 Pashons 1742 AM - 20th Pope of Alexandria. Champion of Orthodoxy against Arianism. Author of the Nicene Creed defence.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-46@coptic-calendar.app
DTSTART;VALUE=DATE:20260522
DTEND;VALUE=DATE:20260523
SUMMARY:St. Pachomius (14 Pashons)
DESCRIPTION:14 Pashons 1742 AM - Father of communal monasticism. Founded the first cenobitic monastery in Upper Egypt.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-47@coptic-calendar.app
DTSTART;VALUE=DATE:20260523
DTEND;VALUE=DATE:20260524
SUMMARY:St. Simon the Zealot (15 Pashons)
DESCRIPTION:15 Pashons 1742 AM - One of the twelve apostles. Preached in Africa and was martyred by crucifixion.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-51@coptic-calendar.app
DTSTART;VALUE=DATE:20260603
DTEND;VALUE=DATE:20260604
SUMMARY:St. Thomas the Apostle (26 Pashons)
DESCRIPTION:26 Pashons 1742 AM - One of the twelve apostles. Preached in India where he was martyred.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-52@coptic-calendar.app
DTSTART;VALUE=DATE:20260610
DTEND;VALUE=DATE:20260611
SUMMARY:Anba Abraam, Bishop of Fayoum (3 Paone)
DESCRIPTION:3 Paone 1742 AM - Bishop of Fayoum (1829-1914). Known as the Friend of the Poor for his extreme generosity.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-53@coptic-calendar.app
DTSTART;VALUE=DATE:20260613
DTEND;VALUE=DATE:20260614
SUMMARY:St. Didymus the Blind (6 Paone)
DESCRIPTION:6 Paone 1742 AM - Theologian of Alexandria who was blind from age 4. Head of the Catechetical School.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-54@coptic-calendar.app
DTSTART;VALUE=DATE:20260623
DTEND;VALUE=DATE:20260624
SUMMARY:St. Onuphrius (Anba Noufer) (16 Paone)
DESCRIPTION:16 Paone 1742 AM - Great desert hermit who lived 60 years in solitude. His story was told by Abba Paphnutius.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-55@coptic-calendar.app
DTSTART;VALUE=DATE:20260627
DTEND;VALUE=DATE:20260628
SUMMARY:Pope Cyril of Alexandria (20 Paone)
DESCRIPTION:20 Paone 1742 AM - 24th Pope of Alexandria. Defender of the title Theotokos at the Council of Ephesus (431 AD).
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-56@coptic-calendar.app
DTSTART;VALUE=DATE:20260701
DTEND;VALUE=DATE:20260702
SUMMARY:St. Moses the Black (24 Paone)
DESCRIPTION:24 Paone 1742 AM - Former robber who became a desert monk. Ordained priest and martyred c. 405 AD.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-57@coptic-calendar.app
DTSTART;VALUE=DATE:20260709
DTEND;VALUE=DATE:20260710
SUMMARY:St. Jude Thaddaeus (2 Epep)
DESCRIPTION:2 Epep 1742 AM - One of the twelve apostles. Also known as Lebbaeus. Preached in Syria and was martyred.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-60@coptic-calendar.app
DTSTART;VALUE=DATE:20260714
DTEND;VALUE=DATE:20260715
SUMMARY:St. Shenouda the Archimandrite (7 Epep)
DESCRIPTION:7 Epep 1742 AM - Father of the White Monastery. Greatest Coptic writer. Lived to over 100 years.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-61@coptic-calendar.app
DTSTART;VALUE=DATE:20260715
DTEND;VALUE=DATE:20260716
SUMMARY:St. Bishoy / St. Karas (8 Epep)
DESCRIPTION:8 Epep 1742 AM - St. Bishoy, beloved of Christ, body remains incorrupt. St. Karas the Anchorite, extreme austerity.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-62@coptic-calendar.app
DTSTART;VALUE=DATE:20260722
DTEND;VALUE=DATE:20260723
SUMMARY:St. Ephrem the Syrian (15 Epep)
DESCRIPTION:15 Epep 1742 AM - Deacon and prolific hymn writer. 'Harp of the Holy Spirit.' Doctor of the Church.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-63@coptic-calendar.app
DTSTART;VALUE=DATE:20260727
DTEND;VALUE=DATE:20260728
SUMMARY:St. Theodore the General (20 Epep)
DESCRIPTION:20 Epep 1742 AM - Roman general martyred for his faith. One of the most venerated military saints.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-64@coptic-calendar.app
DTSTART;VALUE=DATE:20260730
DTEND;VALUE=DATE:20260731
SUMMARY:St. Marina / St. Longinus (23 Epep)
DESCRIPTION:23 Epep 1742 AM - St. Marina, virgin martyr who defeated the devil. St. Longinus, centurion who pierced Christ's side.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-65@coptic-calendar.app
DTSTART;VALUE=DATE:20260731
DTEND;VALUE=DATE:20260801
SUMMARY:St. Abanoub (24 Epep)
DESCRIPTION:24 Epep 1742 AM - Child martyr of Samanoud. Martyred at age 12 during the Diocletian persecution.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-66@coptic-calendar.app
DTSTART;VALUE=DATE:20260802
DTEND;VALUE=DATE:20260803
SUMMARY:St. Joseph the Carpenter (26 Epep)
DESCRIPTION:26 Epep 1742 AM - Foster father of Christ and husband of the Virgin Mary. Patron of families and workers.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-68@coptic-calendar.app
DTSTART;VALUE=DATE:20260813
DTEND;VALUE=DATE:20260814
SUMMARY:Pope Timothy II (7 Mesore)
DESCRIPTION:7 Mesore 1742 AM - 26th Pope of Alexandria (457-477 AD). Defended Orthodoxy during turbulent times.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-70@coptic-calendar.app
DTSTART;VALUE=DATE:20260821
DTEND;VALUE=DATE:20260822
SUMMARY:Habib Guirguis (15 Mesore)
DESCRIPTION:15 Mesore 1742 AM - Archdeacon and great educator of the Coptic Church (1876-1951). Pioneer of Sunday School movement.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-73@coptic-calendar.app
DTSTART;VALUE=DATE:20260828
DTEND;VALUE=DATE:20260829
SUMMARY:St. Augustine of Hippo (22 Mesore)
DESCRIPTION:22 Mesore 1742 AM - Bishop of Hippo and Doctor of the Church. Author of Confessions and City of God.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-74@coptic-calendar.app
DTSTART;VALUE=DATE:20260903
DTEND;VALUE=DATE:20260904
SUMMARY:St. Habakkuk the Prophet (28 Mesore)
DESCRIPTION:28 Mesore 1742 AM - Old Testament prophet. Author of the Book of Habakkuk. 'The just shall live by faith.'
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-76@coptic-calendar.app
DTSTART;VALUE=DATE:20260912
DTEND;VALUE=DATE:20260913
SUMMARY:St. John the Baptist (2 Thoout)
DESCRIPTION:2 Thoout 1743 AM - Forerunner of Christ. Baptized the Lord in the Jordan. 'He must increase, I must decrease.'
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-77@coptic-calendar.app
DTSTART;VALUE=DATE:20260914
DTEND;VALUE=DATE:20260915
SUMMARY:St. Verena (4 Thoout)
DESCRIPTION:4 Thoout 1743 AM - Egyptian saint who traveled to Switzerland. Known for healing and teaching hygiene.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-78@coptic-calendar.app
DTSTART;VALUE=DATE:20260917
DTEND;VALUE=DATE:20260918
SUMMARY:St. Rebecca and her 5 Children (7 Thoout)
DESCRIPTION:7 Thoout 1743 AM - Mother who encouraged her five children to accept martyrdom. Model of faithful motherhood.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-79@coptic-calendar.app
DTSTART;VALUE=DATE:20260922
DTEND;VALUE=DATE:20260923
SUMMARY:Council of Ephesus (431 AD) (12 Thoout)
DESCRIPTION:12 Thoout 1743 AM - Third Ecumenical Council. Affirmed Mary as Theotokos. Condemned Nestorianism.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-83@coptic-calendar.app
DTSTART;VALUE=DATE:20261005
DTEND;VALUE=DATE:20261006
SUMMARY:St. Maurice / Jonah the Prophet (25 Thoout)
DESCRIPTION:25 Thoout 1743 AM - St. Maurice: commander of the Theban Legion. Jonah: prophet who preached to Nineveh.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-84@coptic-calendar.app
DTSTART;VALUE=DATE:20261011
DTEND;VALUE=DATE:20261012
SUMMARY:St. Anastasia (1 Paope)
DESCRIPTION:1 Paope 1743 AM - Roman martyr during the Diocletian persecution. Known for secretly helping imprisoned Christians.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-85@coptic-calendar.app
DTSTART;VALUE=DATE:20261014
DTEND;VALUE=DATE:20261015
SUMMARY:St. Bacchus (4 Paope)
DESCRIPTION:4 Paope 1743 AM - Roman soldier martyred for his faith alongside St. Sergius. Patron of many Coptic churches.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-86@coptic-calendar.app
DTSTART;VALUE=DATE:20261017
DTEND;VALUE=DATE:20261018
SUMMARY:St. Paul the Simple (7 Paope)
DESCRIPTION:7 Paope 1743 AM - Disciple of St. Anthony. Known for extreme simplicity and obedience. Could cast out demons.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-87@coptic-calendar.app
DTSTART;VALUE=DATE:20261020
DTEND;VALUE=DATE:20261021
SUMMARY:St. Sergius (10 Paope)
DESCRIPTION:10 Paope 1743 AM - Roman soldier and companion of St. Bacchus. Martyred for refusing to worship idols.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-88@coptic-calendar.app
DTSTART;VALUE=DATE:20261022
DTEND;VALUE=DATE:20261023
SUMMARY:St. Matthew the Evangelist (12 Paope)
DESCRIPTION:12 Paope 1743 AM - Tax collector who became one of the twelve. Author of the Gospel of Matthew.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-89@coptic-calendar.app
DTSTART;VALUE=DATE:20261026
DTEND;VALUE=DATE:20261027
SUMMARY:St. John Chrysostom (16 Paope)
DESCRIPTION:16 Paope 1743 AM - 'Golden-mouthed' preacher. Archbishop of Constantinople. One of the greatest Church Fathers.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-90@coptic-calendar.app
DTSTART;VALUE=DATE:20261031
DTEND;VALUE=DATE:20261101
SUMMARY:St. Reweis (21 Paope)
DESCRIPTION:21 Paope 1743 AM - Simple Coptic saint known for his childlike faith and miraculous deeds.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-91@coptic-calendar.app
DTSTART;VALUE=DATE:20261101
DTEND;VALUE=DATE:20261102
SUMMARY:St. Luke the Evangelist (22 Paope)
DESCRIPTION:22 Paope 1743 AM - Physician and companion of St. Paul. Author of the Gospel of Luke and Acts of the Apostles.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-92@coptic-calendar.app
DTSTART;VALUE=DATE:20261114
DTEND;VALUE=DATE:20261115
SUMMARY:St. Simon the Tanner (5 Hator)
DESCRIPTION:5 Hator 1743 AM - Coptic cobbler whose faith moved the Mokattam Mountain in Cairo (10th century).
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-93@coptic-calendar.app
DTSTART;VALUE=DATE:20261118
DTEND;VALUE=DATE:20261119
SUMMARY:Council of Nicaea (325 AD) (9 Hator)
DESCRIPTION:9 Hator 1743 AM - First Ecumenical Council. Formulated the Nicene Creed. Condemned Arianism.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-94@coptic-calendar.app
DTSTART;VALUE=DATE:20261124
DTEND;VALUE=DATE:20261125
SUMMARY:St. Mina the Miraculous (15 Hator)
DESCRIPTION:15 Hator 1743 AM - Egyptian soldier martyred in Phrygia. Known for countless miracles. Major pilgrimage site.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-96@coptic-calendar.app
DTSTART;VALUE=DATE:20261126
DTEND;VALUE=DATE:20261127
SUMMARY:St. John Chrysostom (17 Hator)
DESCRIPTION:17 Hator 1743 AM - Departure commemoration of the golden-mouthed preacher.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-97@coptic-calendar.app
DTSTART;VALUE=DATE:20261127
DTEND;VALUE=DATE:20261128
SUMMARY:St. Philip the Apostle (18 Hator)
DESCRIPTION:18 Hator 1743 AM - One of the twelve apostles. From Bethsaida. Led Nathanael to Christ (John 1:43-46).
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-98@coptic-calendar.app
DTSTART;VALUE=DATE:20261201
DTEND;VALUE=DATE:20261202
SUMMARY:Cosmas and Damian (22 Hator)
DESCRIPTION:22 Hator 1743 AM - Unmercenary physicians. Treated the sick without charge. Martyred during Diocletian persecution.
CATEGORIES:c
TRANSP:TRANSPARENT
END:VEVENT
BEGIN:VEVENT
UID:coptic2026-99@coptic-calendar.app
DTSTART;VALUE=DATE:20261204
DTEND;VALUE=DATE:20261205
SUMMARY:Philopater Mercurius (Abu Sefein) (25 Hator)
